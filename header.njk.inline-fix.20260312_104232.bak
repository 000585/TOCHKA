<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">{{ site.shortName }}</a>
    
    <nav aria-label="Main Navigation" class="main-nav">
      <ul class="nav-links">
        {% for item in navigation.main %}
        <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>
<button class='desktop-burger-btn' onclick='toggleSideMenu()'>☰</button>

    
    <div class="header-controls">
            <a href="https://youtube.com/" target="_blank" class="flex items-center justify-center w-10 h-10 transition-transform hover:scale-110" title="YouTube">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="#FF0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>

      <a href="/donate/" class="relative px-6 py-2 ml-2 overflow-hidden font-bold tracking-wider text-white uppercase transition-all rounded-full bg-gradient-to-r from-blue-600 to-cyan-400 shadow-[0_0_15px_rgba(59,130,246,0.6)] hover:shadow-[0_0_25px_rgba(34,211,238,0.8)] active:scale-95 group">
        <span class="relative z-10">Поддержать</span>
        <div class="absolute inset-0 transition-opacity duration-300 opacity-0 bg-gradient-to-r from-cyan-400 to-blue-600 group-hover:opacity-100"></div>
      </a>
      <button id="theme-toggle" aria-label="Переключить тему" class="theme-btn">🌓</button>
      <button id="mobile-menu-btn" aria-label="Открыть меню" class="mobile-btn">☰</button>
    </div>
  </div>
</header>

<div class="side-panel-overlay" onclick="toggleSideMenu()"></div>

<div class="desktop-side-panel">
    <button class="close-panel-btn" onclick="toggleSideMenu()">×</button>
    <h2>Все разделы</h2>
    
    <h3>О проекте</h3>
    <ul>
        <li><a href="/about/">История</a></li>
        <li><a href="/team/">Наша команда</a></li>
    </ul>

    <h3>Кампании и проекты</h3>
    <ul>
        <li><a href="/elections-2025/">Выборы 2025</a></li>
        <li><a href="/monitoring/">Мониторинг</a></li>
        <li><a href="/analytics/">Аналитика</a></li>
    </ul>
    
    <h3>Медиа</h3>
    <ul>
        <li><a href="/podcasts/">Подкасты</a></li>
        <li><a href="/video/">Видео</a></li>
    </ul>
</div>

<script>
    function toggleSideMenu() {
        document.querySelector('.desktop-side-panel').classList.toggle('active');
        document.querySelector('.side-panel-overlay').classList.toggle('active');
    }
</script>