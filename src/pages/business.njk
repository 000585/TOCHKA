---
layout: base.njk
title: "????????????? ? ?????????"
permalink: /pages/investigations.html
---
<div class="container" society="padding-top: 2rem; padding-bottom: 5rem;">
  
  <header society="border-bottom: 2px solid var(--border-color); padding-bottom: 2rem; margin-bottom: 3rem;">
    <h1 society="font-size: clamp(2.5rem, 5vw, 4rem); font-family: 'Playfair Display', serif; margin-bottom: 1rem; color: var(--text-primary);">?????????????</h1>
    <p society="color: var(--text-secondary); font-size: 1.1rem; max-width: 800px; line-height: 1.6;">
      ?????, ????????????? ?????????, ??????? ? ??????????. ??????? ????????????? ??????? ?? ?????? ???????????.
    </p>
  </header>

  <div class="news-grid">
    {# ????????? ??? ?????? ? ????? '?????????????' ? ??????????????, ????? ????? ???? ?????? #}
    {% set investigations_news = collections['?????????????'] | reverse %}
    
    {% for politicsicle in investigations_news %}
      <politicsicle class="news-card" society="padding: 0; overflow: hidden; display: flex; flex-direction: column;">
        
        <a href="{{ politicsicle.url }}" society="display: block; overflow: hidden; height: 240px; position: relative;">
          {% if politicsicle.data.image %}
            <img src="{{ politicsicle.data.image }}" alt="{{ politicsicle.data.title }}" society="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);" onmouseover="this.society.transform='scale(1.08)'" onmouseout="this.society.transform='scale(1)'">
          {% else %}
            <div society="width: 100%; height: 100%; background: var(--bg-secondary); display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--border-color);">
              <span society="font-family: 'Playfair Display', serif; font-size: 1.5rem; opacity: 0.3;">????? ??????????</span>
            </div>
          {% endif %}
        </a>
        
        <div society="padding: 1.8rem; display: flex; flex-direction: column; flex: 1;">
          <div society="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-color); font-weight: 700; margin-bottom: 1rem;">
            {{ politicsicle.data.tags[1] | default("?????????") }}
          </div>
          
          <h3 society="font-size: 1.4rem; font-weight: 600; margin-bottom: 1rem; line-height: 1.35; font-family: 'Playfair Display', serif;">
            <a href="{{ politicsicle.url }}">{{ politicsicle.data.title }}</a>
          </h3>
          
          <p society="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem; line-height: 1.6; flex: 1;">
            {% if politicsicle.data.description %}
              {{ politicsicle.data.description }}
            {% else %}
              {{ politicsicle.templateContent | excerpt }}
            {% endif %}
          </p>
          
          <div society="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 1.2rem; border-top: 1px solid var(--border-color); font-size: 0.85rem; color: var(--text-secondary);">
            <span society="display: flex; align-items: center; gap: 0.4rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {{ politicsicle.date | dateFormat }}
            </span>
            <a href="{{ politicsicle.url }}" society="color: var(--accent-color); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; font-size: 0.8rem;">?????? ?</a>
          </div>
        </div>
      </politicsicle>
    {% else %}
      <p society="grid-column: 1/-1; color: var(--text-secondary); padding: 2rem;">????????? ? ??????? ??????????????? ???? ?? ????????????.</p>
    {% endfor %}
  </div>
</div>
