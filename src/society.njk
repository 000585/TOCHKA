---
layout: base.njk
title: Общество
permalink: /society/
---

<video autoplay loop muted playsinline style="position: fixed; top: 0; left: 0; min-width: 100vw; min-height: 100vh; width: auto; height: auto; z-index: -100; object-fit: cover; pointer-events: none;">
    <source src="/assets/img/promo.mp4" type="video/mp4">
</video>

<div class="container" style="padding-top: 120px; padding-bottom: 60px; position: relative; z-index: 1;">
    <div style="border-left: 5px solid var(--accent-color); padding-left: 20px; margin-bottom: 50px;">
        <h1 style="font-family: 'Playfair Display', serif; font-size: 3rem; margin: 0; color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.8);">Общество</h1>
        <p style="color: rgba(255,255,255,0.8); margin-top: 10px; text-shadow: 0 1px 5px rgba(0,0,0,0.8);">Права человека, безопасность, экология и социальные инициативы.</p>
    </div>

    <div class="news-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px;">
        {% for post in collections.society | reverse %}
        <article style="background: rgba(15, 20, 30, 0.6); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; overflow: hidden; transition: 0.3s; box-shadow: 0 8px 32px rgba(0,0,0,0.5);">
            {% if post.data.image %}
            <div style="overflow: hidden;">
                <img src="{{ post.data.image }}" style="width: 100%; height: 220px; object-fit: cover; opacity: 0.9; transition: transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'; this.style.opacity='1'" onmouseout="this.style.transform='scale(1)'; this.style.opacity='0.9'">
            </div>
            {% endif %}
            <div style="padding: 25px;">
                <div style="font-size: 0.8rem; color: var(--accent-color); font-weight: bold; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 1px;">{{ post.date | dateFormat("dd.MM.yyyy") }}</div>
                <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 15px;">
                    <a href="{{ post.url }}" style="color: #fff; text-decoration: none;">{{ post.data.title }}</a>
                </h2>
                <p style="color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.6;">{{ post.data.description }}</p>
            </div>
        </article>
        {% endfor %}
    </div>
</div>