<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.shortName }}</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/header.css">
  <style>
    .social-link-icon {
      display: flex; align-items: center; justify-content: center;
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--bg-primary); border: 1px solid var(--border-color);
      transition: all 0.3s ease; color: var(--text-primary);
    }
    .social-link-icon:hover {
      border-color: var(--accent-color); color: var(--accent-color);
      transform: translateY(-3px);
    }
    .social-link-icon svg { width: 20px; height: 20px; fill: currentColor; }
  </style>
</head>
<body >
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo" style="font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">{{ site.shortName }}</a>
      <nav class="main-nav">
        <ul class="nav-links">
          {% for item in navigation.main %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {% endfor %}
        </ul>
      </nav>
      <div class="header-controls">
        <button id="theme-toggle" title="??????????? ????">??</button>
        <button id="mobile-menu-btn" title="????">?</button>
      </div>
    </div>
  </header>

  <main class="page-content">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}
  <script src="/assets/js/main.js"></script>

<style id="nav-buttons-css">
    .btn-yt {
        display: inline-flex; align-items: center; gap: 6px;
        background: #FF0000; color: #ffffff !important;
        padding: 5px 14px; border-radius: 20px;
        font-family: sans-serif; font-weight: bold; font-size: 13px; text-decoration: none;
        transition: all 0.3s ease; margin: 0 10px; border: 1px solid transparent;
        box-shadow: 0 4px 10px rgba(255, 0, 0, 0.3);
        white-space: nowrap;
    }
    .btn-yt:hover { background: #e60000; box-shadow: 0 6px 15px rgba(255, 0, 0, 0.6); transform: translateY(-1px); }
    
    .btn-donate {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #001a33, #004080); color: #00ffff !important;
        padding: 5px 14px; border-radius: 8px;
        font-family: sans-serif; font-weight: bold; font-size: 13px; text-decoration: none;
        position: relative; overflow: hidden;
        border: 1px solid rgba(0, 255, 255, 0.4);
        box-shadow: 0 0 12px rgba(0, 102, 204, 0.6);
        transition: all 0.3s ease; margin: 0 10px;
        white-space: nowrap;
    }
    .btn-donate::before {
        content: ''; position: absolute; top: 0; left: -100%;
        width: 50%; height: 100%;
        background: linear-gradient(to right, transparent, rgba(0, 255, 255, 0.4), transparent);
        transform: skewX(-20deg);
        animation: hologram 3s infinite;
    }
    @keyframes hologram {
        0% { left: -100%; }
        20% { left: 200%; }
        100% { left: 200%; }
    }
    .btn-donate:hover { box-shadow: 0 0 18px #00ffff; border-color: #00ffff; transform: translateY(-1px); }
    </style>

<script id="nav-buttons-js">
    document.addEventListener('DOMContentLoaded', function() {
        const links = Array.from(document.querySelectorAll('a'));
        
