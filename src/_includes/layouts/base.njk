<!DOCTYPE html>
<html lang="{{ site.language }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.shortName }}</title>
  <link rel="stylesheet" href="{{ '{{ '/assets/css/main.css' | url }}' | url }}">
  <link rel="stylesheet" href="{{ '{{ '/assets/css/header.css' | url }}' | url }}">
  <style>
    .social-link-icon {
      display: flex; align-items: center; justify-content: center;
      width: 42px; height: 42px; border-radius: 50%;
      background: var(--bg-primary); border: 1px solid var(--border-color);
      transition: all 0.3s ease; color: var(--text-primary);
    }
    .social-link-icon:hover {
      border-color: var(--accent-color); color: var(--accent-color);
      transform: translateY(-3px);
    }
    .social-link-icon svg { width: 20px; height: 20px; fill: currentColor; }
  </style>
</head>
<body >
  {% include "components/header.njk" %}


  <main class="page-content">
    {{ content | safe }}
  </main>

  {% include "components/footer.njk" %}
  <script src="{{ '{{ '/assets/js/main.js' | url }}' | url }}"></script>

<!-- ????????? ?????? "??????????" (???????, ????? ??????) -->
<a href="{{ '{{ '/fundraiser/' | url }}' | url }}" class="mobile-support-btn" style="position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: #ff0000; color: white; padding: 14px 40px; border-radius: 50px; font-weight: 800; text-transform: uppercase; text-decoration: none; box-shadow: 0 8px 20px rgba(255,0,0,0.6); z-index: 10000; border: 2px solid rgba(255,255,255,0.3); letter-spacing: 1px; font-size: 16px; display: none;">??????????</a>
<style>
  @media (max-width: 768px) {
    .mobile-support-btn {
      display: block !important;
      animation: pulse-red 2s infinite;
    }
    @keyframes pulse-red {
      0% { transform: translateX(-50%) scale(1); box-shadow: 0 8px 20px rgba(255,0,0,0.6); }
      50% { transform: translateX(-50%) scale(1.05); box-shadow: 0 12px 30px rgba(255,0,0,0.9); }
      100% { transform: translateX(-50%) scale(1); box-shadow: 0 8px 20px rgba(255,0,0,0.6); }
    }
  }
</style>
</body>
</html>


