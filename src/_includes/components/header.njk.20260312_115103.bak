<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">{{ site.shortName }}</a>
    
    <nav aria-label="Main Navigation" class="main-nav">
      <ul class="nav-links">
        {% for item in navigation.main %}
        <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endfor %}
      </ul>
    </nav>
<button class='desktop-burger-btn' onclick='toggleSideMenu()'>☰</button>

    
        <div class="header-controls" style="display: flex; align-items: center; gap: 15px;">
      <a href="https://youtube.com/" target="_blank" style="display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; background: rgba(255, 255, 255, 0.1); border-radius: 50%; text-decoration: none; border: 1px solid rgba(255,0,0,0.5);" title="YouTube">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="#FF0000"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      
      <a href="/donate/" style="display: inline-block; padding: 8px 20px; background: linear-gradient(90deg, #2563eb, #22d3ee); color: #ffffff !important; font-weight: bold; text-transform: uppercase; text-decoration: none; border-radius: 50px; font-size: 13px; box-shadow: 0 4px 15px rgba(37,99,235,0.4); border: 1px solid rgba(255,255,255,0.2);">
        Поддержать
      </a>

      <button id="theme-toggle" aria-label="Переключить тему" class="theme-btn" style="margin-left: 5px;">🌓</button>
      <button id="mobile-menu-btn" aria-label="Открыть меню" class="mobile-btn">☰</button>
    </div>
  </div>
</header>

<div class="side-panel-overlay" onclick="toggleSideMenu()"></div>

<div class="desktop-side-panel">
    <button class="close-panel-btn" onclick="toggleSideMenu()">×</button>
    <h2>Все разделы</h2>
    
    <h3>О проекте</h3>
    <ul>
        <li><a href="/about/">История</a></li>
        <li><a href="/team/">Наша команда</a></li>
    </ul>

    <h3>Кампании и проекты</h3>
    <ul>
        <li><a href="/elections-2025/">Выборы 2025</a></li>
        <li><a href="/monitoring/">Мониторинг</a></li>
        <li><a href="/analytics/">Аналитика</a></li>
    </ul>
    
    <h3>Медиа</h3>
    <ul>
        <li><a href="/podcasts/">Подкасты</a></li>
        <li><a href="/video/">Видео</a></li>
    </ul>
</div>

<script>
    function toggleSideMenu() {
        document.querySelector('.desktop-side-panel').classList.toggle('active');
        document.querySelector('.side-panel-overlay').classList.toggle('active');
    }
</script>