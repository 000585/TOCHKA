<div class="container">
  
  <section class="hero">
    <div class="hero__grid">
      {% set recent_news = collections.news | slice(0, 4) %}
      
      {% if recent_news.length > 0 %}
      <div class="hero__main" style="background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 100%), url('{{ recent_news[0].data.image }}') center/cover no-repeat; border: none; min-height: 450px;">
        <span class="hero__badge">?????????</span>
        <h2 class="hero__title"><a href="{{ recent_news[0].url }}" style="color: #ffffff;">{{ recent_news[0].data.title }}</a></h2>
        <div class="news-card__meta" style="border: none; padding: 0; color: #b3b3b3;">
          <span>{{ recent_news[0].date | dateFormat }}</span>
        </div>
      </div>
      {% endif %}

      <div class="hero__secondary">
        {% for article in recent_news %}
          {% if loop.index0 > 0 %}
          <div class="hero__card" style="padding: 1rem;">
            {% if article.data.image %}
            <img src="{{ article.data.image }}" alt="{{ article.data.title }}" style="width: 100px; height: 100px; object-fit: cover; border-radius: 8px;">
            {% endif %}
            <div style="flex: 1;">
              <h3 class="hero__card-title" style="font-size: 1.1rem;"><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
              <div class="news-card__meta" style="border: none; padding: 0;">
                {{ article.date | dateFormat }}
              </div>
            </div>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section>
    <h2 class="section-title">????? ???????????</h2>
    <div class="popular-grid">
      {% set popular_news = collections.news | slice(1, 4) %}
      {% for article in popular_news %}
      <div class="popular-item">
        <span class="popular-number">{{ loop.index }}</span>
        <a href="{{ article.url }}" class="popular-title">{{ article.data.title }}</a>
      </div>
      {% endfor %}
    </div>
  </section>

  <section>
    <h2 class="section-title">????????? ??????????</h2>
    <div class="news-grid">
      {% set more_news = collections.news | slice(4, 10) %}
      {% for article in more_news %}
        <article class="news-card" style="padding: 0; overflow: hidden;">
          {% if article.data.image %}
          <img src="{{ article.data.image }}" alt="{{ article.data.title }}" style="width: 100%; height: 220px; object-fit: cover; border-bottom: 1px solid var(--border-color);">
          {% endif %}
          <div style="padding: 1.8rem; display: flex; flex-direction: column; flex: 1;">
            <h3 class="hero__card-title"><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
            <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem;">{{ article.templateContent | excerpt }}</p>
            <div class="news-card__meta" style="margin-top: auto;">
              <span>{{ article.date | dateFormat }}</span>
              <a href="{{ article.url }}" style="color: var(--accent-color); font-weight: 500;">?????? ?</a>
            </div>
          </div>
        </article>
      {% else %}
        <p style="color: var(--text-secondary);">????????? ????????? ? ??????????.</p>
      {% endfor %}
    </div>
  </section>

</div>


