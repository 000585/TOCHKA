---
layout: base.njk
title: "????? ??????????"
---
<style>
  /* ??????????? ????? ??? ????? ??????? */
  .news-feed-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  
  .news-feed-item {
    display: flex;
    gap: 2rem;
    background: var(--bg-secondary);
    border-radius: 16px;
    padding: 1.5rem;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
  }
  
  .news-feed-item:hover {
    border-color: var(--accent-color);
    transform: translateY(-4px);
    box-shadow: 0 15px 30px var(--shadow-color);
  }
  
  .news-feed-thumb {
    flex-shrink: 0;
    width: 280px;
    height: 190px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    background: var(--bg-primary);
  }
  
  .news-feed-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .news-feed-item:hover .news-feed-thumb img {
    transform: scale(1.06);
  }
  
  .news-feed-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
  }

  /* ????????? ??? ????????? ??????? */
  @media (max-width: 768px) {
    .news-feed-item {
      flex-direction: column;
      padding: 1rem;
      gap: 1.2rem;
    }
    .news-feed-thumb {
      width: 100%;
      height: 220px;
    }
  }
</style>

<div class="container" style="padding-top: 2rem; padding-bottom: 5rem; max-width: 1000px;">
  
  <header style="border-bottom: 2px solid var(--border-color); padding-bottom: 2rem; margin-bottom: 3rem;">
    <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); font-family: 'Playfair Display', serif; margin-bottom: 1rem; color: var(--text-primary);">????? ??????????</h1>
    <p style="color: var(--text-secondary); font-size: 1.1rem; max-width: 800px; line-height: 1.6;">
      ??????? ???????, ???????????? ????????????? ? ????????? ?? ???????? ?????? ???????????. ????? ?????? ?????????? ? ??????????????? ???????.
    </p>
    
    <div style="display: flex; gap: 0.8rem; margin-top: 2rem; flex-wrap: wrap;">
      <span style="background: var(--text-primary); color: var(--bg-primary); padding: 0.4rem 1.2rem; border-radius: 30px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; cursor: default;">??? ?????????</span>
      <span style="border: 1px solid var(--border-color); color: var(--text-secondary); padding: 0.4rem 1.2rem; border-radius: 30px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--accent-color)'; this.style.color='var(--accent-color)'" onmouseout="this.style.borderColor='var(--border-color)'; this.style.color='var(--text-secondary)'">?????????????</span>
      <span style="border: 1px solid var(--border-color); color: var(--text-secondary); padding: 0.4rem 1.2rem; border-radius: 30px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--accent-color)'; this.style.color='var(--accent-color)'" onmouseout="this.style.borderColor='var(--border-color)'; this.style.color='var(--text-secondary)'">?????????</span>
    </div>
  </header>

  <div class="news-feed-list">
    {% for article in collections.news | reverse %}
      <article class="news-feed-item">
        
        <a href="{{ article.url }}" class="news-feed-thumb">
          {% if article.data.image %}
            <img src="{{ article.data.image }}" alt="{{ article.data.title }}">
          {% else %}
            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
              <span style="font-family: 'Playfair Display', serif; font-size: 1.5rem; opacity: 0.2;">??</span>
            </div>
          {% endif %}
          
          {% if article.data.ai_enhanced %}
            <span style="position: absolute; top: 0.8rem; left: 0.8rem; background: var(--accent-color); color: #000; padding: 0.2rem 0.6rem; font-size: 0.7rem; font-weight: 700; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px;">AI</span>
          {% endif %}
        </a>
        
        <div class="news-feed-content">
          <div style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent-color); font-weight: 700; margin-bottom: 0.8rem;">
            {{ article.data.tags[0] | default("???????") | replace("???????", "??????") }}
          </div>
          
          <h3 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 0.8rem; line-height: 1.35; font-family: 'Playfair Display', serif;">
            <a href="{{ article.url }}">{{ article.data.title }}</a>
          </h3>
          
          <p style="color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem; line-height: 1.6;">
            {% if article.data.description %}
              {{ article.data.description }}
            {% else %}
              {{ article.templateContent | excerpt }}
            {% endif %}
          </p>
          
          <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; font-size: 0.85rem; color: var(--text-secondary);">
            <span style="display: flex; align-items: center; gap: 0.4rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {{ article.date | dateFormat }}
            </span>
            <span style="font-weight: 500; display: flex; align-items: center; gap: 0.4rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line></svg>
              {{ article.data.author | default("????????") }}
            </span>
          </div>
        </div>
      </article>
    {% else %}
      <p style="text-align: center; padding: 4rem; color: var(--text-secondary); font-size: 1.1rem; border-radius: 12px; border: 1px dashed var(--border-color);">
        ????????? ???? ?? ????????????.
      </p>
    {% endfor %}
  </div>

</div>
