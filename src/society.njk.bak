---
layout: base.njk
title: Общество
permalink: /society/
---
<div class="container" style="padding-top: 120px; padding-bottom: 60px;">
    <div style="border-left: 5px solid var(--accent-color); padding-left: 20px; margin-bottom: 50px;">
        <h1 style="font-family: 'Playfair Display', serif; font-size: 3rem; margin: 0;">Общество</h1>
        <p style="color: var(--text-secondary); margin-top: 10px;">Права человека, безопасность, экология и социальные инициативы.</p>
    </div>

    <div class="news-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px;">
        {% for post in collections.society | reverse %}
        <article style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden; transition: 0.3s;">
            {% if post.data.image %}
            <img src="{{ post.data.image }}" style="width: 100%; height: 220px; object-fit: cover;">
            {% endif %}
            <div style="padding: 25px;">
                <div style="font-size: 0.8rem; color: var(--accent-color); font-weight: bold; margin-bottom: 10px; text-transform: uppercase;">{{ post.date | dateFormat("dd.MM.yyyy") }}</div>
                <h2 style="font-family: 'Playfair Display', serif; font-size: 1.5rem; margin-bottom: 15px;">
                    <a href="{{ post.url }}" style="color: var(--text-primary); text-decoration: none;">{{ post.data.title }}</a>
                </h2>
                <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">{{ post.data.description }}</p>
            </div>
        </article>
        {% endfor %}
    </div>
</div>